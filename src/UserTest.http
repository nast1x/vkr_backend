# ============================================
# ПОЛУЧЕНИЕ ДАННЫХ (GET)
# ============================================

# 1. Получить всех пользователей
GET http://localhost:8080/api/users


GET http://localhost:8080/api/users/1

### 3. Получить пользователя по email
GET http://localhost:8080/api/users/email/coach@example.com

### 4. Поиск пользователей по фамилии
GET http://localhost:8080/api/users/search?lastName=Иванов

### 5. Получить всех воспитанников тренера (например, ID тренера = 1)
GET http://localhost:8080/api/users/coach/1/trainees

# ============================================
# СОЗДАНИЕ (POST)
# ============================================

### 6. Создать тренера
POST http://localhost:8080/api/users
Cookie: access_token=eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiIxMyIsImVtYWlsIjoibmFzdGF5dGl4MUBnbWFpbC5jb20iLCJyb2xlIjoiQXRobGV0ZSIsInR5cGUiOiJhY2Nlc3MiLCJpc3MiOiJzcG9ydC1rdXJzLWFwaSIsImlhdCI6MTc3NTg1MjMwNiwiZXhwIjoxNzc1ODUzMjA2fQ.SibOhPFO8E5fgnF4LBemHo8UaOLbTm5FxDEz0Xnqjh27wy5k7u3YgrMFmybeq-sd
Content-Type: application/json

{
  "email": "admin@admin.com",
  "password": "admin_admin",
  "lastName": "admin",
  "firstName": "admin",
  "middleName": "admin",
  "birthDate": "1900-01-01",
  "gender": "Female",
  "roleId": 1,
  "coachId": null
}

### 7. Создать воспитанника с привязкой к тренеру
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "email": "trainee@example.com",
  "password": "password123",
  "lastName": "Петров",
  "firstName": "Петр",
  "middleName": "Петрович",
  "birthDate": "2005-03-20",
  "gender": "Male",
  "roleId": 2,
  "coachId": 1
}


